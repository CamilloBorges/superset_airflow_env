# webserver_config.py - Azure Entra ID OAuth Configuration for Airflow
# Localização: airflow/config/webserver_config.py

from flask_appbuilder.security.manager import AUTH_OAUTH
import os

# --------------------------------------------------
# Azure Entra ID OAuth Configuration
# --------------------------------------------------

AUTH_TYPE = AUTH_OAUTH

OAUTH_PROVIDERS = [
    {
        'name': 'azure',
        'icon': 'fa-windows',
        'token_key': 'access_token',
        'remote_app': {
            'client_id': os.getenv('AZURE_AIRFLOW_CLIENT_ID', 'YOUR_CLIENT_ID_HERE'),
            'client_secret': os.getenv('AZURE_AIRFLOW_CLIENT_SECRET', 'YOUR_CLIENT_SECRET_HERE'),
            'api_base_url': 'https://graph.microsoft.com/v1.0/',
            'client_kwargs': {
                'scope': 'openid email profile User.Read'
            },
            'access_token_url': f"https://login.microsoftonline.com/{os.getenv('AZURE_TENANT_ID', 'YOUR_TENANT_ID')}/oauth2/v2.0/token",
            'authorize_url': f"https://login.microsoftonline.com/{os.getenv('AZURE_TENANT_ID', 'YOUR_TENANT_ID')}/oauth2/v2.0/authorize",
            'server_metadata_url': f"https://login.microsoftonline.com/{os.getenv('AZURE_TENANT_ID', 'YOUR_TENANT_ID')}/v2.0/.well-known/openid-configuration",
        }
    }
]

# Auto-registrar usuários no primeiro login
AUTH_USER_REGISTRATION = True
AUTH_USER_REGISTRATION_ROLE = "Viewer"  # Papel padrão: Viewer, User, Op, Admin

# Implementar Security Manager customizado do Airflow
from airflow.www.security import AirflowSecurityManager

class AzureSecurityManager(AirflowSecurityManager):
    def oauth_user_info(self, provider, response=None):
        """
        Extrai informações do usuário do Azure AD
        """
        if provider == 'azure':
            import requests
            access_token = response.get('access_token')
            
            # Obter dados do usuário via Microsoft Graph
            me = requests.get(
                'https://graph.microsoft.com/v1.0/me',
                headers={'Authorization': f'Bearer {access_token}'}
            ).json()
            
            return {
                'username': me.get('userPrincipalName', '').split('@')[0],
                'name': me.get('displayName', ''),
                'email': me.get('mail') or me.get('userPrincipalName'),
                'first_name': me.get('givenName', ''),
                'last_name': me.get('surname', ''),
                'role_keys': ['Viewer'],  # Papel padrão
            }

SECURITY_MANAGER_CLASS = AzureSecurityManager

# --------------------------------------------------
# Configurações Opcionais
# --------------------------------------------------

# Mapear grupos do Azure AD para roles do Airflow (Avançado)
# Roles disponíveis: Admin, Op, User, Viewer, Public
# AUTH_ROLES_MAPPING = {
#     "Airflow-Admins": ["Admin"],
#     "Airflow-Operators": ["Op"],
#     "Airflow-Users": ["User"],
#     "Airflow-Viewers": ["Viewer"],
# }

# Sincronizar roles a cada login
# AUTH_ROLES_SYNC_AT_LOGIN = True

# Logging
import logging
logging.basicConfig(level=logging.INFO)
