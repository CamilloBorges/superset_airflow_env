# =============================================================================
# CONFIGURAÇÕES GERAIS
# =============================================================================
COMPOSE_PROJECT_NAME=data-platform
TIMEZONE=America/Sao_Paulo

# Domínio público (usado para Cloudflare Tunnel)
PUBLIC_DOMAIN=bomgado.com.br

# =============================================================================
# OPENLDAP - Servidor de Autenticação Unificada
# =============================================================================

# Organização e domínio LDAP
LDAP_ORGANISATION=Bomgado Data Platform
LDAP_DOMAIN=bomgado.local

# Base DN (construído a partir do domínio)
LDAP_BASE_DN=dc=bomgado,dc=local

# Senha do administrador LDAP (cn=admin,dc=bomgado,dc=local)
LDAP_ADMIN_PASSWORD=changeme_ldap_admin_password

# Senha de configuração LDAP (cn=admin,cn=config)
LDAP_CONFIG_PASSWORD=changeme_ldap_config_password

# Usuário read-only para bind de serviços
LDAP_READONLY_USER=readonly
LDAP_READONLY_PASSWORD=changeme_readonly_password

# Bind DN para serviços (Superset, Airflow)
LDAP_BIND_DN=cn=admin,dc=bomgado,dc=local
LDAP_BIND_PASSWORD=${LDAP_ADMIN_PASSWORD}

# Configurações de conexão LDAP
LDAP_HOST=openldap
LDAP_PORT=389

# =============================================================================
# POSTGRESQL - Banco de Dados de Metadados
# =============================================================================
POSTGRES_USER=dataplatform
POSTGRES_PASSWORD=changeme_strong_password

# URL-encoded password (para connection strings)
# Se sua senha contém @, encode como %40  (ex: Bomgado@233751 vira Bomgado%40233751)
# Se contém :, encode como %3A
# Se contém /, encode como %2F
POSTGRES_PASSWORD_URLENCODED=changeme_strong_password

POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Bancos de dados específicos
POSTGRES_AIRFLOW_DB=airflow_db
POSTGRES_SUPERSET_DB=superset_db

# =============================================================================
# REDIS - Message Broker e Cache
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password

# =============================================================================
# APACHE AIRFLOW
# =============================================================================
# Executor: LocalExecutor ou CeleryExecutor
AIRFLOW_EXECUTOR=CeleryExecutor

# Configurações do Airflow Core
AIRFLOW__CORE__FERNET_KEY=changeme_generate_with_python_cryptography_fernet
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__CORE__PARALLELISM=32
AIRFLOW__CORE__MAX_ACTIVE_RUNS_PER_DAG=16

# Configurações do Webserver
AIRFLOW__WEBSERVER__SECRET_KEY=changeme_secret_key_airflow_webserver
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=false
AIRFLOW_WEBSERVER_PORT=8080

# Admin User inicial (criado na inicialização, depois gerenciado via LDAP)
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin123
AIRFLOW_ADMIN_FIRSTNAME=Admin
AIRFLOW_ADMIN_LASTNAME=User
AIRFLOW_ADMIN_EMAIL=admin@bomgado.local

# Configurações do Celery (se usar CeleryExecutor)
AIRFLOW__CELERY__BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres/${POSTGRES_AIRFLOW_DB}

# UID para permissões de arquivo (Linux/Mac: use `id -u`, Windows: use 50000)
AIRFLOW_UID=50000

# =============================================================================
# APACHE SUPERSET
# =============================================================================
SUPERSET_SECRET_KEY=changeme_superset_secret_key_min_42_chars_recommended
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=admin123
SUPERSET_ADMIN_FIRSTNAME=Admin
SUPERSET_ADMIN_LASTNAME=Superset
SUPERSET_ADMIN_EMAIL=admin@bomgado.local
SUPERSET_WEBSERVER_PORT=8088

# Configurações do Celery para Superset
SUPERSET_CELERY_BROKER=redis://:${REDIS_PASSWORD}@redis:6379/1
SUPERSET_CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/2

# =============================================================================
# APACHE HOP
# =============================================================================
HOP_SERVER_PORT=8081
HOP_SERVER_USER=cluster
HOP_SERVER_PASS=cluster

# Variáveis de ambiente customizadas para projetos Hop
HOP_PROJECT_FOLDER=/opt/hop/projects
HOP_CONFIG_FOLDER=/opt/hop/config
HOP_SHARED_FOLDER=/shared/data

# =============================================================================
# PORTAS EXPOSTAS (para acesso externo via Cloudflare Tunnel)
# =============================================================================
# Cloudflare Tunnel se conecta diretamente a essas portas (sem Nginx)
POSTGRES_EXTERNAL_PORT=5432
REDIS_EXTERNAL_PORT=6379
AIRFLOW_EXTERNAL_PORT=8080
SUPERSET_EXTERNAL_PORT=8088
HOP_EXTERNAL_PORT=8081
LDAP_EXTERNAL_PORT=389
LDAP_ADMIN_EXTERNAL_PORT=8082

# =============================================================================
# CLOUDFLARE TUNNEL - Mapeamento de Domínios
# =============================================================================
# Configure seu Cloudflare Tunnel para rotear:
#
# bi.bomgado.com.br -> http://superset:8088
# airflow.bomgado.com.br -> http://airflow-webserver:8080
# hop.bomgado.com.br -> http://hop-server:8081
# ldap.bomgado.com.br -> http://phpldapadmin:80
#
# Cloudflare gerencia SSL/TLS automaticamente
