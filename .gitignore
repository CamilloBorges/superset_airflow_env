# Arquivos de ambiente com dados sensíveis
.env
*.env
!.env.example

# Logs do Airflow
airflow/logs/*
!airflow/logs/.gitkeep

# Dados do Superset
superset/data/*
!superset/data/.gitkeep

# Metadados e cache do Hop
hop/metadata/*
!hop/metadata/.gitkeep

# Dados compartilhados (armazenamento temporário)
shared/data/*
!shared/data/.gitkeep

# Arquivos de banco de dados local
*.db
*.sqlite
*.sqlite3

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
ENV/
env/

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Docker
.docker/

# Certificados e chaves
*.pem
*.key
*.crt
*.p12

