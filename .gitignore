# Arquivos de ambiente com dados sensíveis
.env
*.env
!.env.example

# Arquivos de configuração com secrets (não commitados)
airflow/config/webserver_config.py
superset/config/superset_config.py
**/config/*_config.py
!**/config/*_config.py.example

# Certificados SSL
certs/
*.pem
*.key
*.crt
*.p12
*.pfx

# Arquivos temporários com possíveis secrets
*.txt
!requirements.txt
!**/requirements.txt
Untitled-*

# Logs do Airflow
airflow/logs/*
!airflow/logs/.gitkeep

# Dados do Superset
superset/data/*
!superset/data/.gitkeep

# Metadados e cache do Hop
hop/metadata/*
!hop/metadata/.gitkeep

# Dados compartilhados (armazenamento temporário)
shared/data/*
!shared/data/.gitkeep

# Arquivos de banco de dados local
*.db
*.sqlite
*.sqlite3

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
ENV/
env/

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Docker
.docker/

# Certificados e chaves
*.pem
*.key
*.crt
*.p12

# Backups
*.bak
*.backup
*.old

# Arquivos temporários
*.tmp
*.temp
*.log
